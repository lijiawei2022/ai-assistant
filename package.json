{
  "name": "ai-assitant",
  "displayName": "AI Assistant Plugin",
  "description": "VSCode plugin for AI assistant integration (no RAG)",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ai-assitant.helloWorld",
    "onCommand:ai-assitant.showPanel",
    "onCommand:ai-assitant.analyzeCode",
    "onView:aiAssistantView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-assitant.helloWorld",
        "title": "AI Assistant: Hello World"
      },
      {
        "command": "ai-assitant.showPanel",
        "title": "AI Assistant: Show Panel"
      },
      {
        "command": "ai-assitant.analyzeCode",
        "title": "AI Assistant: Analyze Selected Code"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "aiAssistantView",
          "name": "AI Assistant"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ai-assitant.analyzeCode",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "16.x",
    "@types/vscode": "^1.70.0",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "langchain": "^1.3.5",
    "nodejieba": "^3.5.8"
  }
}
