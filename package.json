{
  "name": "ai-assitant",
  "displayName": "AI Assistant Plugin",
  "description": "AI编程助教 - 基于知识图谱与RAG的C语言程序设计智能辅导系统",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ai-assitant.helloWorld",
    "onCommand:ai-assitant.showPanel",
    "onCommand:ai-assitant.analyzeCode",
    "onView:aiAssistantView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-assitant.helloWorld",
        "title": "AI Assistant: Hello World"
      },
      {
        "command": "ai-assitant.showPanel",
        "title": "AI Assistant: Show Panel"
      },
      {
        "command": "ai-assitant.analyzeCode",
        "title": "AI Assistant: Analyze Selected Code"
      },
      {
        "command": "ai-assitant.syntaxCheck",
        "title": "AI Assistant: Syntax Check"
      },
      {
        "command": "ai-assitant.learningPath",
        "title": "AI Assistant: Learning Path"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiAssistant",
          "title": "AI Assistant",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "aiAssistant": [
        {
          "type": "webview",
          "id": "aiAssistantView",
          "name": "AI Assistant"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ai-assitant.analyzeCode",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus"
      },
      {
        "command": "ai-assitant.syntaxCheck",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus"
      },
      {
        "command": "ai-assitant.learningPath",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "AI 编程助教",
      "properties": {
        "aiAssistant.llmBaseUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "LLM推理服务地址（支持远程服务器，如 http://192.168.1.100:8000）"
        },
        "aiAssistant.embeddingBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama Embedding服务地址（用于向量嵌入）"
        },
        "aiAssistant.llmModel": {
          "type": "string",
          "default": "huggingface-serve",
          "description": "LLM模型名称"
        },
        "aiAssistant.embeddingModel": {
          "type": "string",
          "default": "bge-m3",
          "description": "Embedding模型名称"
        },
        "aiAssistant.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "当LLM服务不可用时，是否自动在本地启动serve.py"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "16.x",
    "@types/vscode": "^1.70.0",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@xenova/transformers": "^2.17.2",
    "graphology": "^0.26.0",
    "nodejieba": "^3.5.8"
  }
}
